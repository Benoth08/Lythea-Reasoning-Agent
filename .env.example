# Lythéa V3 — environment configuration
#
# Copy this file to ``.env`` and override only what you need.
# All variables have sensible defaults; an empty .env is fine.
#
# Variable names are case-insensitive. The "LYTHEA_" prefix is required.

# ─────────────────────────────────────────────────────────────────────
# SDM — Sparse Distributed Memory (working memory, session-scoped)
# ─────────────────────────────────────────────────────────────────────
# Hyper-vector dimension. Higher = more capacity, more RAM/VRAM.
# LYTHEA_SDM_DIM=1024
# Number of address rows. Higher = more storage but slower top-k.
# LYTHEA_SDM_ROWS=4096
# Top-k neighbours used for read/write.
# LYTHEA_SDM_K=8
# Base exponential decay rate per microsleep cycle (0..1).
# LYTHEA_SDM_DECAY=0.95
# Norm threshold below which a row is pruned to zero.
# LYTHEA_SDM_PRUNE_THRESHOLD=1.0


# ─────────────────────────────────────────────────────────────────────
# MHN — Modern Hopfield Network (episodic memory, session-scoped)
# ─────────────────────────────────────────────────────────────────────
# Maximum number of patterns kept in the FIFO ring buffer.
# LYTHEA_MHN_MAX_PATTERNS=512
# Embedding dimension (must match the encoder, default GLiNER 768).
# LYTHEA_MHN_DIM=768
# Inverse temperature for softmax attention. Higher = sharper recall.
# LYTHEA_MHN_BETA=8.0


# ─────────────────────────────────────────────────────────────────────
# Salience filter (3-cascade gate before memorisation)
# ─────────────────────────────────────────────────────────────────────
# Minimum character length for N1 stage.
# LYTHEA_SALIENCE_MIN_LENGTH=8
# Heuristic score threshold for N2 stage (0..1).
# LYTHEA_SALIENCE_MIN_SCORE=0.25
# Cosine threshold above which a message is considered redundant (N3).
# LYTHEA_SALIENCE_REDUNDANCY_THRESHOLD=0.92


# ─────────────────────────────────────────────────────────────────────
# Entropy / doubt detection (per-token confidence)
# ─────────────────────────────────────────────────────────────────────
# Below this normalised entropy, output is considered confident.
#
# Calibration history (validated empirically in prod):
#   0.6 — original default. Empirically too strict for any modern
#         instruction-tuned model. Mean entropies stay around
#         0.05–0.10 even on speculative questions, so doubt always
#         rounded to <0.3 → label always "fait" (no gradient at all).
#   0.2 — current default. Restores the fait/intuition/hypothese
#         spectrum on instruction-tuned models. Thinking models
#         (Qwen3-Thinking, R1, etc.) still sit at "fait" even with
#         this threshold — that's intrinsic to their architecture
#         and no global setting can fix it.
# LYTHEA_ENTROPY_THRESHOLD=0.2
# Window size (tokens) for rolling doubt mean.
# LYTHEA_ENTROPY_DOUBT_WINDOW=8


# ─────────────────────────────────────────────────────────────────────
# Composite surprise weights (should sum to ~1.0)
# ─────────────────────────────────────────────────────────────────────
# LYTHEA_SURPRISE_W_STRUCTURAL=0.4
# LYTHEA_SURPRISE_W_EPISODIC=0.35
# LYTHEA_SURPRISE_W_PREDICTIVE=0.25


# ─────────────────────────────────────────────────────────────────────
# Generation
# ─────────────────────────────────────────────────────────────────────
# Max new tokens per response.
# LYTHEA_MAX_NEW_TOKENS=1024
# Max past turns kept in history budget.
# LYTHEA_MAX_HISTORY_TURNS=10


# ─────────────────────────────────────────────────────────────────────
# Knowledge Graph (persistent identity memory)
# ─────────────────────────────────────────────────────────────────────
# Confidence required to promote a pending entity to active.
# LYTHEA_KG_ACTIVE_THRESHOLD=0.5
# How long pending entities are kept before pruning.
# LYTHEA_KG_PENDING_TTL_HOURS=24
# Fuzzy match ratio for entity deduplication.
# LYTHEA_KG_FUZZY_THRESHOLD=0.85


# ─────────────────────────────────────────────────────────────────────
# Retrieval (Chroma + BM25 + cross-encoder)
# ─────────────────────────────────────────────────────────────────────
# Candidates retrieved before reranking.
# LYTHEA_RETRIEVAL_TOP_N=20
# Final results returned after reranking.
# LYTHEA_RETRIEVAL_RERANK_TOP=5
# RRF fusion constant.
# LYTHEA_RETRIEVAL_RRF_K=60


# ─────────────────────────────────────────────────────────────────────
# Web search (DuckDuckGo via ddgs)
# ─────────────────────────────────────────────────────────────────────
# Maximum iterative rounds.
# LYTHEA_WEB_MAX_ROUNDS=3
# Word-overlap threshold for early stopping.
# LYTHEA_WEB_STABILITY_THRESHOLD=0.3


# ─────────────────────────────────────────────────────────────────────
# Microsleep — consolidation cycle (Buzsáki replay)
# ─────────────────────────────────────────────────────────────────────
# Trigger every N exchanges.
# LYTHEA_MICROSLEEP_INTERVAL=5
# Trigger after N seconds of inactivity.
# LYTHEA_MICROSLEEP_INACTIVITY=180
# Top-k SDM rows boosted during rehearsal.
# LYTHEA_MICROSLEEP_REHEARSE_K=16
# Rehearsal boost factor (1+boost multiplier).
# LYTHEA_MICROSLEEP_BOOST=0.15


# ─────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────
# Bind host (0.0.0.0 for tunneled access, 127.0.0.1 for strictly local).
# LYTHEA_HOST=0.0.0.0
# Bind port.
# LYTHEA_PORT=7860


# ─────────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────────
# Bearer token required for non-loopback or Cloudflare-tunneled requests.
# Generate one with:  openssl rand -hex 32
# Leave empty for fully open mode (development only).
# LYTHEA_AUTH_TOKEN=

# Strict mode: require token even for loopback (127.0.0.1) requests.
# Useful when sharing your local machine with other users.
# LYTHEA_AUTH_STRICT=0


# ─────────────────────────────────────────────────────────────────────
# Rate limiting (loopback requests are exempt)
# ─────────────────────────────────────────────────────────────────────
# Format: "<count>/<period>" — periods: second, minute, hour, day.
# LYTHEA_RATE_LIMIT_CHAT=60/minute
# LYTHEA_RATE_LIMIT_MODEL_LOAD=10/minute


# ─────────────────────────────────────────────────────────────────────
# Trust remote code (security)
# ─────────────────────────────────────────────────────────────────────
# When 1, transformers will execute custom Python from HuggingFace
# model repositories. This is a security risk for untrusted models.
# Default 0 — only enable for specific models that require it.
# LYTHEA_ALLOW_REMOTE_CODE=0


# ─────────────────────────────────────────────────────────────────────
# Embedding caches (perf tuning)
# ─────────────────────────────────────────────────────────────────────
# LRU cache size for EntityExtractor.encode() — ~3 KB/entry.
# Same query is encoded 3+ times per cognitive cycle; caching saves CPU.
# Set 0 to disable. Default 1024 ≈ 3 MB.
# LYTHEA_EMBED_CACHE_SIZE=1024

# LRU cache size for HFModelWrapper.analyze_input() — ~100 KB/entry.
# Cleared automatically on every model load/unload. Default 64 ≈ 6 MB.
# LYTHEA_ANALYZE_CACHE_SIZE=64


# ─────────────────────────────────────────────────────────────────────
# Cross-encoder reranker
# ─────────────────────────────────────────────────────────────────────
# Model used to rerank retrieval results. BGE-reranker-v2-m3 (~570 MB)
# is multilingual and excellent for French. Lighter alternative:
# "BAAI/bge-reranker-base" (~280 MB).
# LYTHEA_CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3

# Minimum rerank score to keep a candidate. Higher = stricter
# (fewer results, higher quality). 0 = keep everything reranked.
#
# Calibration history (validated empirically in prod):
#   0.5 — original default. Too strict on conversational queries
#         like "Tu te souviens de X ?" — the cross-encoder rates
#         meta-questions ↔ stored content at <0.05, so all results
#         get filtered out and Chroma never reaches the LLM.
#   0.0 — too permissive: lets through unrelated stories that
#         pollute responses (observed with a Loki story leaking
#         into a strawberry-image description).
#   0.2 — current default. Sweet spot: filters noise but keeps
#         the genuinely-pertinent doc (typical observation:
#         9 → 1 retained at score=0.91).
# LYTHEA_CROSS_ENCODER_MIN_SCORE=0.2


# ─────────────────────────────────────────────────────────────────────
# Image captioner (Qwen2-VL or BLIP)
# ─────────────────────────────────────────────────────────────────────
# Maximum new tokens generated by the Qwen2VL captioner per image.
# 150 (the previous hardcoded value) truncated rich photos
# mid-sentence. 256 gives Qwen2VL enough room while keeping the
# prompt budget bounded. BLIP is unaffected — it's laconic by design.
# LYTHEA_CAPTION_MAX_TOKENS=256


# ─────────────────────────────────────────────────────────────────────
# Coreference inference
# ─────────────────────────────────────────────────────────────────────
# When the user writes "Je travaille chez X" without naming themselves,
# GLiNER does not extract a person — so :func:`_link_co_occurrences`
# would create no relation. As a fallback we look up the most-recently-
# mentioned person in the KG and use them as the implicit anchor.
#
# Window in seconds: only persons mentioned within this period are
# eligible. Beyond it, we assume the user has moved on conversationally
# and we do not infer the relation.
# LYTHEA_COREFERENCE_WINDOW_SEC=1800

# Confidence assigned to relations created via this fallback. Set
# below the direct-extraction confidence (0.6) if you want to filter
# inferred relations out later by confidence threshold.
# LYTHEA_COREFERENCE_INFERRED_CONFIDENCE=0.6


# ─────────────────────────────────────────────────────────────────────
# Soft memory (prefix-tuning) — OPT-IN
# ─────────────────────────────────────────────────────────────────────
# Long-term parametric memory via prefix-tuning. When enabled, exposes
# /api/soft-memory/{train,rollback,reset,status}. See soft_memory.py
# for the rationale on why prefix-tuning over LoRA.
# Default OFF — only enable once you have a few hundred exchanges of
# memory accumulated.
# LYTHEA_ENABLE_SOFT_MEMORY=0

# Length of the learnable prefix (in tokens). 32 is a good default
# for 7B models; reduce to 16 for 3B models.
# LYTHEA_SOFT_MEMORY_PREFIX_LENGTH=32

# Training learning rate.
# LYTHEA_SOFT_MEMORY_LEARNING_RATE=0.001

# Epochs per train() call.
# LYTHEA_SOFT_MEMORY_EPOCHS=1


# ─── V3.9 Cascade generation (Gemini draft → local synthesis) ───────────
#
# When enabled, generation goes through a two-stage pipeline: Gemini
# produces a rich draft, then the locally loaded model synthesises it
# in Lythéa's concise voice and feeds its latents to SDM/MHN/KG.
#
# Setup (Gemini free tier, 1500 req/day, no credit card needed):
#  1. Go to https://aistudio.google.com/app/apikey
#  2. Click "Create API key" → "Create API key in new project"
#  3. Copy the key (it starts with AIzaSy...)
#  4. Paste below as GOOGLE_API_KEY=...
#  5. Set LYTHEA_ENABLE_CASCADE=true
#  6. chmod 600 .env  (so only your user can read it)
#  7. Restart Lythéa (bash launch.sh)
#
# IMPORTANT: the free tier means Google may use your conversations to
# improve their products. Switch to paid tier (activate billing in the
# AI Studio console) if you want privacy guarantees. The same key works
# for both — only the billing flag changes.

# Master switch — must be true for any cascade activity.
# LYTHEA_ENABLE_CASCADE=false

# Google AI Studio API key. Format: AIzaSy + 33 alphanumerics.
# GOOGLE_API_KEY=

# Gemini model id. Free tier (2026-06): gemini-3.5-flash (best, GA),
# gemini-3-flash, gemini-3.1-flash-lite (+ 2.5 Flash family). Pro = paid.
# Vérifie l'id exact dans AI Studio (les suffixes Gemini changent).
# LYTHEA_CASCADE_GEMINI_MODEL=gemini-3.5-flash

# Synthesis kicks in only when Gemini's draft is longer than this many
# (approximate) tokens. Below it, the draft is shipped as-is. Set to 0
# to always synthesise.
# LYTHEA_CASCADE_SYNTHESIS_THRESHOLD_TOKENS=50

# Hard ceiling on the synthesised output length.
# LYTHEA_CASCADE_SYNTHESIS_MAX_TOKENS=120

# Hard ceiling on Gemini's draft. 800 tokens ≈ 600 words ≈ a long
# answer. Anything beyond bleeds quota for marginal gain.
# LYTHEA_CASCADE_GEMINI_MAX_TOKENS=800

# Sampling temperature for the Gemini draft. 0.7 is Google's
# recommended default; lower = more deterministic.
# LYTHEA_CASCADE_GEMINI_TEMPERATURE=0.7

# Soft local-counter for the daily quota. Server enforces the real
# limit; this is just for the UI warning.
# LYTHEA_CASCADE_DAILY_QUOTA_HINT=1500

# ─── Web search providers ───────────────────────────────────────────
#
# Lythéa V4.0.3 — pluggable web search backends.
#
# Default chain (when WEB_SEARCH_PROVIDER=auto):
#   Tavily → Serper → Brave → SearXNG → DDG
#
# Each provider is tried in order; the first to return results wins.
# A provider without an API key is silently skipped — no error, no
# log spam. So you can configure 0, 1, 2, or all 3 API-based providers
# depending on your budget and quality needs.
#
# RECOMMENDATION: get free keys for Tavily + Serper (5 min total).
# Together they give 3500 free searches/month with Google-quality
# results, vastly better than DDG alone.

# Provider selection. Options:
#   auto    (default) — composite chain (skips unavailable ones)
#   tavily  — Tavily only (requires TAVILY_API_KEY)
#   serper  — Serper only (requires SERPER_API_KEY)
#   brave   — Brave only (requires BRAVE_API_KEY, paid since 2026)
#   searxng — SearXNG only (open-source meta-search, no key)
#   ddg     — DuckDuckGo only (limited quality, always available)
# WEB_SEARCH_PROVIDER=auto


# ── Tavily AI Search (RECOMMENDED PRIMARY) ──────────────────────────
#
# Why: Tavily is built for LLM/RAG. Returns a synthesised "answer"
# (2-3 sentence summary) ON TOP of raw snippets, saving the model
# tokens during the <think> phase.
#
# Free tier: 1000 requests/month, no credit card required.
#
# How to get a key (2 min):
#   1. Go to https://tavily.com
#   2. Sign up with email
#   3. Verify, then copy your API key from the dashboard
#   4. Paste below (uncommented)
#
# TAVILY_API_KEY=tvly-...


# ── Serper Google Search (RECOMMENDED SECONDARY) ────────────────────
#
# Why: Serper is a direct Google Search API proxy. Lowest latency
# (~300ms), Google-identical quality, returns Knowledge Graph and
# Answer Box (featured snippets) which are RAG gold.
#
# Free tier: 2500 requests/month, no credit card required.
#
# How to get a key (2 min):
#   1. Go to https://serper.dev
#   2. Sign up with email or Google
#   3. Copy your API key from the dashboard
#   4. Paste below (uncommented)
#
# SERPER_API_KEY=...

# Optional Serper tuning (defaults shown):
# SERPER_COUNTRY=fr        # ISO country code biasing results
# SERPER_LANG=fr           # UI language


# ── Brave Search API (PAID since late 2026) ─────────────────────────
#
# Brave removed the free tier in late 2026. Paid plans start at
# ~$5/mois for 2000 req. Keep in chain only if you have an active
# subscription, otherwise it's silently skipped.
#
# BRAVE_API_KEY=BSA-...
# BRAVE_SEARCH_COUNTRY=FR
# BRAVE_SEARCH_LANG=fr
# BRAVE_SAFESEARCH=off


# ── SearXNG (free, self-hostable) ───────────────────────────────────
#
# Open-source meta-search engine. Public instances often slow or
# rate-limited; self-host for production reliability.
# Self-host docs: https://docs.searxng.org/admin/installation-docker.html
#
# SEARXNG_INSTANCE_URL=https://my-searxng.example.org
