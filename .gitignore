# ───────────────────── Secrets / config locale ─────────────────────
# Le .env RÉEL ne doit JAMAIS être commité — seul .env.example l'est.
# (clés API : OpenRouter / Z.ai / HuggingFace, etc.)
.env
.env.*
!.env.example
*.key
*.pem
*.p12
secrets.json
credentials.json
service_account*.json
*_token.txt
hf_token*

# ─────────────────── Données runtime Lythéa (PRIVÉ) ───────────────────
# Mémoire, stores, dumps de conversations = données personnelles.
# Ne JAMAIS publier : elles sont régénérées au runtime.
chroma/
chroma_db/
chromadb/
*.chroma
data/
memory_store/
*_memory.pkl
*.sdm
*.mhn
*.kg
*.gpickle
sessions/
conversations/
uploads/
user_data/

# Logs
logs/
*.log
*.out

