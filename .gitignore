# Les poids se téléchargent au 1er run (plusieurs dizaines de Go).
models/
weights/
*.safetensors
*.bin
*.pt
*.pth
*.gguf
*.onnx
.cache/
hf_cache/
huggingface/
.huggingface/
transformers_cache/

